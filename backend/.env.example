PORT=3011
NODE_ENV=development
DB_PATH=./data/buku.db
STORAGE_DIR=./data/storage
FRONTEND_URL=http://localhost:5183

# Admin tunggal dibuat otomatis saat boot jika tabel admin masih kosong
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# AI teks (outline & konten bab) — multi-provider, isi salah satu atau lebih.
# Provider yang key-nya kosong tidak akan muncul sebagai pilihan di UI.
OPENROUTER_API_KEY=
OPENCODE_API_KEY=
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# AI gambar — default Gemini 3 Pro Image, pakai GOOGLE_AI_API_KEY yang sama dengan provider teks "Google AI"
# di atas (satu akun Google AI Studio yang sama mendukung model teks maupun gambar).
IMAGE_PROVIDER=gemini
